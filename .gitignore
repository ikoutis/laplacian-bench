# In-repo checkout of CombinatorialMultigrid.jl, developed by setup.jl via its
# local `develop` path (clone/update it with performance-experiments/wulver/
# fetch_cmg.sh). It is a separate git repository and is never tracked here.
/CombinatorialMultigrid.jl/

# Raw chol-vs-kcycle benchmark results. These are regenerated by
# chol_vs_kcycle.jl on every run; only the public tables
# (paper_comparison.{csv,md}, coverage.txt, summary.tsv) are tracked. Keeping
# the .jld2 out of git avoids bloat and stale runs polluting make_paper_tables.
/performance-analyses/chol-vs-kcycle/*.jld2
